############################
attack_logs/
telemetry/
analytics/
metrics/
detections/

############################
# Ignore Everything Inside These
############################
evidence/**
captures/**
generated_reports/**
logs/**
uploads/**
downloads/**
runtime/**
temp/**

############################
# Keep Folder Structure
############################
!logs/.gitkeep
!captures/.gitkeep
!evidence/.gitkeep
!generated_reports/.gitkeep
!uploads/.gitkeep
!downloads/.gitkeep
!runtime/.gitkeep
!temp/.gitkeep

############################
# End
