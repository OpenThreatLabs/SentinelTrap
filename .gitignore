# ==========================================================
# Multi-Layer Honeypot Framework for Cyber Attack Analysis
# Universal .gitignore
# ==========================================================

############################
# Python
############################
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

############################
# Python Virtual Environment
############################
venv/
.venv/
env/
ENV/
virtualenv/
.python-version

############################
# Environment Variables
############################
.env
.env.*
!.env.example

############################
# Secrets & Credentials
############################
secrets/
keys/
private_keys/
credentials/
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks

############################
# Databases
############################
*.db
*.db3
*.sqlite
*.sqlite3
*.sqlite-journal
*.sql

############################
# Logs
############################
logs/
log/
*.log
*.out
*.err
*.pid

############################
# Captured Packets
############################
*.pcap
*.pcapng
captures/

############################
# Digital Forensics Evidence
############################
evidence/
artifacts/
memory_dumps/
disk_images/
*.mem
*.raw
*.dd
*.E01
*.001

############################
# Malware Samples
############################
malware/
samples/
quarantine/

############################
# Reports (Generated)
############################
generated_reports/
reports/output/
exports/

############################
# Uploaded Files
############################
uploads/
downloads/
temp/
tmp/

